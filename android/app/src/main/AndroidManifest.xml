<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Сеть нужна для Supabase (БД, Storage, Auth). В debug-манифесте она
         декларируется отдельно для нужд Flutter tool, но release-сборка
         читает только этот файл — без явного разрешения на проде
         все сетевые вызовы молча падают. -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <!-- Android 13+ требует явное разрешение от пользователя на показ
         пуш-уведомлений. На Android < 13 объявление здесь — no-op.
         Запрос системного диалога делает PushService.registerForCurrentUser
         после OTP-логина. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <!-- Микрофон для голосовых сообщений в ИИ-ассистенте. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <!-- Firebase Analytics транзитивно подмешивает в склеенный манифест
         разрешение на рекламный идентификатор (AD_ID). Рекламы в приложении
         нет и рекламный ID мы не используем — убираем разрешение, иначе
         Google Play требует заполнять декларацию рекламного ID и придирается
         по AdMob-политике. tools:node="remove" вырезает то, что добавила
         библиотека при слиянии манифестов. -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID"
        tools:node="remove"/>
    <application
        android:label="Диспетчер №1"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="false"
        tools:replace="android:allowBackup">
        <!-- allowBackup=false: иначе Android авто-бэкап сохранял данные
             приложения (включая сохранённую сессию входа) и восстанавливал
             их при переустановке — свежеустановленное приложение оказывалось
             уже авторизованным под чужим/прошлым номером. Это и UX-баг,
             и риск безопасности. tools:replace — чтобы наше значение
             победило при слиянии манифестов с библиотеками. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
        <!-- Дефолтный канал для FCM, если в payload пуша не указан channel_id.
             Канал с id "default" создаётся клиентом через
             flutter_local_notifications при старте приложения
             (см. PushHandler.initialize). Без этого мета-флага и канала
             на устройстве Android 8+ молча отбрасывает пуши. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="default" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- На Android 11+ launchUrl(tel:) и подобное возвращают false без
             объявленной видимости пакетов в <queries>. Без этих интентов
             кнопки «Позвонить исполнителю», «Открыть в Я.Картах»,
             «Открыть карту», «Отправить email» молча не работают на
             свежих устройствах. -->
        <intent>
            <action android:name="android.intent.action.DIAL"/>
            <data android:scheme="tel"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="tel"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="mailto"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="https"/>
        </intent>
        <!-- geo: — стандартная Android-схема для адресов на карте.
             Все картографические приложения (Яндекс Карты, Google Maps,
             2ГИС, MAPS.ME и др.) объявляют intent-filter на эту схему,
             поэтому при нажатии на адрес система сама показывает
             chooser «Открыть с помощью». -->
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="geo"/>
        </intent>
        <!-- Deeplinks конкретных картографических приложений: чтобы
             пользовательский выбор в bottom-sheet «Открыть адрес в»
             корректно открывал выбранное приложение, а не дефолтное.
             Без этих queries на Android 11+ launchUrl бросит
             PlatformException и наш fallback на web уйдёт не туда. -->
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="yandexmaps"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="dgis"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="comgooglemaps"/>
        </intent>
        <package android:name="ru.yandex.yandexmaps"/>
        <package android:name="ru.dublgis.dgismobile"/>
        <package android:name="com.google.android.apps.maps"/>
    </queries>
</manifest>
