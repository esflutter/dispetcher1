# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Figma API caches (большие JSON, не нужны в репо)
.figma_cache/

# Local agent/session files
.claude/

# --- Секреты / ключи / окружение ---
# Любые env-файлы, пароли, ключи — никогда в репозиторий.
# Поверх этого: .env.example коммитится как образец (там только имена, без значений).
.env
.env.*
!.env.example
*.env
secrets/
# Локальные скрипты запуска с реальными ключами (Supabase и т.п.)
run_dev.sh
run_dev.bat
run_prod.sh
run_prod.bat
# VSCode launch-конфиг может содержать --dart-define=SUPABASE_ANON_KEY=...
.vscode/launch.json
# MCP-конфиг может содержать Basic auth с реальным паролем от Supabase.
# Коммитится только .mcp.json.example.
.mcp.json
!.mcp.json.example
# Страховка: любые файлы с суффиксом _local.dart — не коммитятся
**/*_local.dart
# Keystore / подписи Android
/android/key.properties
/android/app/*.jks
/android/app/*.keystore
# Supabase / сертификаты
*.pem
*.key
*.crt
!**/assets/**/*.pem
