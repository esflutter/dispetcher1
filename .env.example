# Шаблон конфигурации. Скопируйте в .env и заполните реальными значениями.
# НИКОГДА не коммитьте .env с настоящими ключами.

# URL self-hosted Supabase (Beget) — тот же, что и у приложения исполнителя
SUPABASE_URL=https://your-subdomain.beget.app

# Публичный anon-ключ Supabase (JWT вида eyJhbGc...).
# Этот ключ безопасен для клиента — защита через RLS-политики в БД.
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxx.yyy
